{
    "tailwind-fold.autoFold": false,
    "biome.enabled": false,
    "eslint.useFlatConfig": true,
    "tailwindCSS.experimental.classRegex": [
        [
            "cva\\(((?:[^()]|\\([^()]*\\))*)\\)",
            "[\"'`]([^\"'`]*).*?[\"'`]"
        ],
        [
            "cx\\(((?:[^()]|\\([^()]*\\))*)\\)",
            "(?:'|\"|`)([^']*)(?:'|\"|`)"
        ]
    ],
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.unusedImports": "explicit",
            "source.fixAll.pylance": "explicit",
            "source.sort.json": "explicit"
        }
    }
}
